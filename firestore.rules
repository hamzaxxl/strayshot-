rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "rhhhhsj@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    // Domain Validators
    function isValidUser() {
      let allowed = ['uid', 'displayName', 'photoURL', 'facebookUrl', 'bio', 'role', 'ratingSum', 'ratingCount', 'averageRating', 'isBanned', 'createdAt'];
      let required = ['uid', 'displayName', 'role', 'ratingSum', 'ratingCount', 'averageRating', 'isBanned', 'createdAt'];
      return hasOnlyAllowedFields(allowed) && hasRequiredFields(required) &&
             request.resource.data.uid is string &&
             request.resource.data.displayName is string && request.resource.data.displayName.size() < 100 &&
             (!('photoURL' in request.resource.data) || (request.resource.data.photoURL is string && request.resource.data.photoURL.size() < 1000)) &&
             (!('facebookUrl' in request.resource.data) || (request.resource.data.facebookUrl is string && request.resource.data.facebookUrl.size() < 500)) &&
             (!('bio' in request.resource.data) || (request.resource.data.bio is string && request.resource.data.bio.size() < 1000)) &&
             request.resource.data.role in ['user', 'admin'] &&
             isPositive('ratingSum') && isPositive('ratingCount') && isPositive('averageRating') &&
             request.resource.data.isBanned is bool &&
             request.resource.data.createdAt is string;
    }

    function isValidListing() {
      let allowed = ['id', 'sellerId', 'gameName', 'title', 'description', 'images', 'tags', 'status', 'createdAt'];
      let required = ['id', 'sellerId', 'gameName', 'title', 'description', 'images', 'tags', 'status', 'createdAt'];
      return hasOnlyAllowedFields(allowed) && hasRequiredFields(required) &&
             request.resource.data.id is string &&
             request.resource.data.sellerId is string &&
             request.resource.data.gameName is string && request.resource.data.gameName.size() < 100 &&
             request.resource.data.title is string && request.resource.data.title.size() < 200 &&
             request.resource.data.description is string && request.resource.data.description.size() < 5000 &&
             request.resource.data.images is list && request.resource.data.images.size() <= 10 &&
             request.resource.data.tags is list && request.resource.data.tags.size() <= 10 &&
             request.resource.data.status in ['active', 'removed'] &&
             request.resource.data.createdAt is string;
    }

    function isValidReview() {
      let allowed = ['id', 'reviewerId', 'targetUserId', 'rating', 'comment', 'status', 'createdAt'];
      let required = ['id', 'reviewerId', 'targetUserId', 'rating', 'comment', 'status', 'createdAt'];
      return hasOnlyAllowedFields(allowed) && hasRequiredFields(required) &&
             request.resource.data.id is string &&
             request.resource.data.reviewerId is string &&
             request.resource.data.targetUserId is string &&
             request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
             request.resource.data.comment is string && request.resource.data.comment.size() < 1000 &&
             request.resource.data.status in ['active', 'removed'] &&
             request.resource.data.createdAt is string;
    }

    function isValidComment() {
      let allowed = ['id', 'listingId', 'authorId', 'text', 'status', 'createdAt'];
      let required = ['id', 'listingId', 'authorId', 'text', 'status', 'createdAt'];
      return hasOnlyAllowedFields(allowed) && hasRequiredFields(required) &&
             request.resource.data.id is string &&
             request.resource.data.listingId is string &&
             request.resource.data.authorId is string &&
             request.resource.data.text is string && request.resource.data.text.size() < 1000 &&
             request.resource.data.status in ['active', 'removed'] &&
             request.resource.data.createdAt is string;
    }

    function isValidNotification() {
      let allowed = ['id', 'userId', 'type', 'sourceId', 'message', 'read', 'createdAt'];
      let required = ['id', 'userId', 'type', 'sourceId', 'message', 'read', 'createdAt'];
      return hasOnlyAllowedFields(allowed) && hasRequiredFields(required) &&
             request.resource.data.id is string &&
             request.resource.data.userId is string &&
             request.resource.data.type in ['review', 'comment'] &&
             request.resource.data.sourceId is string &&
             request.resource.data.message is string && request.resource.data.message.size() < 500 &&
             request.resource.data.read is bool &&
             request.resource.data.createdAt is string;
    }

    // Users
    match /users/{userId} {
      allow read: if true; // Public profiles needed for marketplace
      allow create: if isAuthenticated() && isValidUser() && uidUnchanged() && 
                    ((isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.isBanned == false) || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && uidNotModified() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isBanned == resource.data.isBanned && request.resource.data.ratingSum == resource.data.ratingSum && request.resource.data.ratingCount == resource.data.ratingCount && request.resource.data.averageRating == resource.data.averageRating) || isAdmin() || 
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSum', 'ratingCount', 'averageRating']))); // Allow anyone to update ratings
      allow delete: if isAdmin();
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidListing() && request.resource.data.sellerId == request.auth.uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false;
      allow update: if isAuthenticated() && isValidListing() && request.resource.data.sellerId == resource.data.sellerId && 
                    ((request.auth.uid == resource.data.sellerId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false) || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.sellerId);
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview() && request.resource.data.reviewerId == request.auth.uid && request.resource.data.targetUserId != request.auth.uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false;
      allow update: if isAuthenticated() && isValidReview() && request.resource.data.reviewerId == resource.data.reviewerId && request.resource.data.targetUserId == resource.data.targetUserId &&
                    ((request.auth.uid == resource.data.reviewerId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false) || isAdmin());
      allow delete: if isAdmin();
    }

    // Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment() && request.resource.data.authorId == request.auth.uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false;
      allow update: if isAuthenticated() && isValidComment() && request.resource.data.authorId == resource.data.authorId && request.resource.data.listingId == resource.data.listingId &&
                    ((request.auth.uid == resource.data.authorId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false) || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.authorId);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidNotification(); // Anyone can trigger a notification
      allow update: if isOwner(resource.data.userId) && isValidNotification() && request.resource.data.userId == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
